---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'About';
const description = 'About Thought Process.';
const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const permalink = new URL(`${basePath}about`, Astro.site).href;
---

<BaseLayout title={title} description={description} permalink={permalink} current="about">
  <div class="container">
    <h1>About</h1>
    <figure class="about-image">
      <img src={`${basePath}assets/jasonpaolasini.jpg`} alt="Portrait of Jason Paolasini" width="280" height="280">
    </figure>
    <p>
      Thought Process is my corner of the internet for writing things down before they disappear.
      It is part blog, part notebook, and part running archive of ideas that are still taking shape.
    </p>
    <p>
      My name is Jason Paolasini. I am an engineering leader with more than a decade of experience
      working in large enterprise environments, and I am deeply obsessed with the cloud native space.
    </p>
    <p>
      Most of what I publish here sits somewhere between software, systems, leadership, and personal
      practice. Sometimes that means technical notes from something I am building. Sometimes it means
      a clearer explanation of a lesson I had to learn the slow way.
    </p>
    <p>
      I like writing that is concrete, useful, and honest about uncertainty. If an idea is here, it
      is because I think it is worth examining in public, not because I think it is finished.
    </p>
    <p>
      Over time this site should become a record of what I am paying attention to: tools, workflows,
      decisions, habits, and the thought process behind the work.
    </p>
  </div>
</BaseLayout>

<style>
  .about-image {
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    box-shadow: 0 18px 45px rgba(0, 0, 0, 0.18);
    height: 280px;
    float: right;
    margin: 0 0 2em 2.5em;
    overflow: hidden;
    width: 280px;
  }

  .about-image img {
    display: block;
    height: 100%;
    height: 280px;
    object-fit: cover;
    object-position: center top;
    width: 100%;
  }

  @media (max-width: 1020px) {
    .about-image {
      float: none;
      margin: 0 auto 2em;
    }
  }
</style>
