---
const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`
---

<div>
  <img src={`${basePath}assets/jasonpaolasini.jpg`} alt="Profile photo">
  <p>
    Hi, I'm <strong>Jason</strong>. This is where I share thoughts and insights on cloud native computing,
    Kubernetes, open source, and the ideas and problems worth thinking through.
  </p>
</div>

<style>
  div {
    align-items: center;
    display: flex;
  }

  img {
    width: 100px;
    height: 100px;
    border-radius: 100px;
    display: block;
    margin-right: 20px;
  }

  p {
    font-size: 1.125rem;
  }
</style>
