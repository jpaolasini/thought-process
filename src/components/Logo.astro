---
const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`
---

<style>
  img {
    display: block;
    width: 150px;
  }

  @media screen and (max-width: 520px) {
    img {
      display: none;
    }
  }
</style>

<a href={basePath}>
  <img alt="Blog Logo" src={`${basePath}assets/logo.png`} width="150" height="100" />
</a>
